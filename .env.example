# IMSS Lab Appointment Scheduling POC - Environment Template
# Copy this to .env and fill in your actual credentials

# --- Gmail OAuth (Service Account) ---
# The email address of your Google Service Account
GMAIL_SERVICE_ACCOUNT=your-bot@your-project.iam.gserviceaccount.com

# The full JSON string from your downloaded service account key file
# Wrap the entire JSON in single quotes to handle special characters
GMAIL_CREDENTIALS_JSON='{"type": "service_account", "project_id": "...", ...}'

# --- OpenClaw Security ---
# A secure random string for Gateway authentication (used by nodes/clients)
# You can generate one with: openssl rand -hex 24
OPENCLAW_GATEWAY_TOKEN=

# --- Environment ---
NODE_ENV=production
